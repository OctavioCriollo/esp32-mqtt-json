/*secrets.h.example — Template for local credentials.
==========================================================================
Copy this file to include/secrets.h and fill in real values.
include/secrets.h is gitignored and must NEVER be committed.

The credentials that previously lived hardcoded in the source were exposed
in the public Git history and must be considered compromised: rotate them
on the router and the MQTT broker before reusing this firmware.
==========================================================================*/
#pragma once

/*WiFi*/
#define WIFI_SSID       "your-wifi-ssid"
#define WIFI_PASSWORD   "your-wifi-password"

/*MQTT broker*/
#define MQTT_SERVER      "your-broker.example.com"
#define MQTT_PORT        8883
#define MQTT_CLIENT_USER "your-mqtt-user"
#define MQTT_CLIENT_PASS "your-mqtt-password"

/*TLS: by default the broker certificate is validated against the CA in
include/ca_cert.h (ISRG Root X1 / Let's Encrypt). If your broker uses a
different CA, replace that PEM. As a temporary diagnostic you can disable
validation by uncommenting the next line (MITM-vulnerable, avoid):*/
//#define MQTT_TLS_INSECURE

/*Password for the web configuration portal (user: admin). Can be changed
later from the portal itself; stored in NVS.*/
#define WEB_ADMIN_PASS "changeme"
